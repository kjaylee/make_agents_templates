{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @forge/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @forge/schema db:generate",
    "db:migrate": "pnpm --filter @forge/schema db:migrate",
    "db:seed": "tsx scripts/seed-templates.ts"
  },
  "devDependencies": {
    "@forge/schema": "workspace:*",
    "@types/node": "^22.7.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  }
}
