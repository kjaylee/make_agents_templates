# ─── LLM (OpenAI-compatible endpoint) ────────────────────────
# Any OpenAI-compatible API. The openai npm package + custom baseURL
# works with Modal, vLLM, Ollama, Together, Fireworks, etc.
LLM_BASE_URL=https://api.us-west-2.modal.direct/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=zai-org/GLM-5.1-FP8
# Optional: a smaller/faster model for classifier and linter stages.
# Falls back to LLM_MODEL if not set.
# LLM_MODEL_FAST=

# ─── Database (Neon) ──────────────────────────────────────────
# Create a Neon project, use the pooled connection string for runtime
# and the direct connection string for drizzle-kit migrations.
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/forge?sslmode=require

# ─── Anthropic (optional fallback) ───────────────────────────
# Only needed if you want Anthropic as a fallback provider.
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Clerk (Auth) ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare R2 (traces, receipts) ────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=forge-traces

# ─── Phase 3: Nocturnal Forge ────────────────────────────────
# Cron secret for Vercel Cron protection
CRON_SECRET=random-secret-string

# Resend API key (optional, for Nocturnal Forge emails)
# RESEND_API_KEY=re_xxx
